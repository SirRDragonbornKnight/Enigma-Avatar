{
  "name": "enigma-avatar",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop Mate-style companion: any rigged glTF/GLB/VRM/FBX floating on a transparent, always-on-top desktop overlay (spring physics, facial lip-sync, emotes).",
  "main": "shell/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm run format:check && npm test",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "electron": "^42.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@pixiv/three-vrm": "^3.5.3",
    "koffi": "^3.0.2",
    "three": "^0.184.0"
  }
}
